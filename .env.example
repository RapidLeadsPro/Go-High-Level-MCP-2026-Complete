# GoHighLevel API Configuration
GHL_API_KEY=your_private_integration_api_key_here
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_LOCATION_ID=your_location_id_here

# Server Configuration
MCP_SERVER_PORT=8000
NODE_ENV=development

# Railway / Vapi entrypoint (npm run start:vapi) — public base URL for OAuth metadata
SERVER_URL=https://your-service.up.railway.app
OAUTH_SECRET=change_me_to_a_long_random_secret

# Optional override when not using Railway PORT (defaults with PORT or 3000)
# VAPI_MCP_PORT=3000

# Optional: For AI features
OPENAI_API_KEY=your_openai_key_here_optional
